<section class="available-content">
{{#scheduled_content}}
    <h2>{{content_heading}}</h2>
    {{#Text}}
        <p>{{content_body}}</p>
    {{/Text}}
    {{#Audio}}
        <p>SOME AUDIO GOES HERE {{content_url}}</p>
        <div class="spinner htmx-indicator" id="spinner">
            <img src="/serve/images/graphics/loading/gif/inline" alt="loading spinner" />
        </div>
        <div hx-post="/controllers/audio_player.php" hx-vals='{{track}}' hx-trigger="load" hx-target="this" hx-swap="outerHTML" htmx-indicator="#spinner"></div>
    {{/Audio}}
    <p class='date'>{{content_pub_date}}</p>
{{/scheduled_content}}
</section>