{{>html_header}}
<div id="hero-container">
    <div id="logo">
        <img src="/serve/images/logos/UnbelievableTruth-logo-white_web/png/inline" />
    </div>
    <div class="hero-tree">
        <img src="/serve/images/graphics/CB_tree_col/png/inline" />
    </div>
    <div class="videoContainer">
    <video id="heroVid" poster="/serve/videos/ril_hero_poster/jpg/inline" autoplay loop muted>
        <source src="/serve/videos/{{background}}_hero_small/mp4/inline" type="video/mp4" />
        Your browser does not support the video tag. Sozzard!
    </video>
    </div>
</div>
<div id="callToAction">
    <div>The new album <a href="https://unbelievabletruth.lnk.to/richinnerlife" target="_blank">Rich Inner Life</a> out now</div>
    <section class="emailForm">
        <div>Join our email list for news:</div>
        <form action="#" id="emailList">
            <input type="text" id="email" placeholder="email address" autocomplete="email" /> <br />
            <input type="text" id="name" placeholder="name (optional)" autocomplete="name" /> <br />
            <input type="submit" id="emailSubmit" value="enter your email" autocomplete="email" />
        </form>
    </section>
</div>

{{>html_footer}}
